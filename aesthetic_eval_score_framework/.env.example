# Dataset
AES_OUTPUT_ROOT=outputs
AVA_JSONL=/path/to/ava_score.jsonl
AVA_IMAGE_ROOT=/path/to/AVA/images
AVA_SMOKE_JSONL=data/ava_smoke_64.jsonl
AVA_SMOKE_MANIFEST=outputs/ava_smoke_manifest.txt

# Optional Hugging Face mirror
# HF_ENDPOINT=https://hf-mirror.com

# Official repository roots required by some adapters
ARTIMUSE_REPO=/path/to/ArtiMuse
ARTQUANT_REPO=/path/to/ArtQuant
QALIGN_REPO=/path/to/Q-Align
UNIPERCEPT_REPO=/path/to/UniPercept
LLAVA_REPO=/path/to/LLaVA

# Local model checkpoints
ARTIMUSE_MODEL=/path/to/models/ArtiMuse
ARTQUANT_WEIGHTS=/path/to/models/ArtQuant/APDD
MPLUG_OWL2_MODEL=/path/to/models/mplug-owl2-llama2-7b
AESEXPERT_MODEL=/path/to/models/AesMMIT_LLaVA_v1.5_7b_240325
UNIPERCEPT_MODEL=/path/to/models/UniPercept
ONEALIGN_MODEL=/path/to/models/one-align
QSIT_MODEL=/path/to/models/q-sit
QWEN3VL_MODEL=/path/to/models/qwen_vl_4B
INTERNVL35_MODEL=/path/to/models/InternVL3_5-8B
LLAVA_ONEVISION_MODEL=/path/to/models/LLaVA_OneVision_1_5_8B_Instruct
GENERIC_MLLM_MODEL=/path/to/models/Generic-MLLM
